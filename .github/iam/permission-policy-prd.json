      ],
      "Resource": [
        "arn:aws:ssm:ap-northeast-1::document/AWS-RunShellScript",
        "arn:aws:ec2:ap-northeast-1:420184924451:instance/i-03bd4d530f4d6a31b"
      ]
    }
  ]
}
